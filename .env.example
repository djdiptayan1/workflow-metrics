PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use a current sb_publishable_... key, or the legacy anon key.
PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Docker + local Supabase only: server-side URL reachable from the app container.
# SUPABASE_INTERNAL_URL=http://host.docker.internal:54321
# Required for privileged server operations such as shared workflow preferences.
# Use a current sb_secret_... key, or the legacy service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# Required for direct pnpm/Node runs. Docker Compose overrides this with its internal Redis service.
# Use rediss:// with TLS for managed Redis outside the bundled Compose stack.
REDIS_URL=redis://localhost:6379

# Production only: set to your public app URL so OAuth redirects back to the app instead of localhost.
# PUBLIC_APP_URL=https://metrics.example.com
# adapter-node origin. Compose defaults this to http://localhost:5173.
# ORIGIN=https://metrics.example.com

# ─── GitHub App (AI Optimization → Apply as PR) ────────────────────────────
# Create a GitHub App at https://github.com/settings/apps/new with:
#   Permissions: Contents (Read & Write), Pull requests (Read & Write), Workflows (Read & Write)
#   Setup URL: https://metrics.example.com/auth/github-app/callback
#   Local Setup URL: http://localhost:5173/auth/github-app/callback
#   Callback URL: leave empty; Webhook: inactive
#
# GITHUB_APP_ID: the numeric App ID shown on the App settings page
# GITHUB_APP_PRIVATE_KEY: the RSA private key downloaded from the App settings page.
#   Store the full PEM content (multi-line), or collapse newlines to literal \n for single-line secrets.
# GITHUB_APP_SLUG: the URL slug of your App (e.g. "workflow-metrics-bot" from github.com/apps/workflow-metrics-bot)
# Leave these commented unless Apply as PR is configured.
# GITHUB_APP_ID=your-github-app-id
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_SLUG=your-github-app-slug
